package com.example.graphicsapp;

import android.content.Context;
import android.graphics.*;
import android.util.AttributeSet;
import android.view.View;

public class DrawView extends View {

    Paint paint = new Paint();

    // ✅ This constructor is REQUIRED when using View in XML
    public DrawView(Context context, AttributeSet attrs) {
        super(context, attrs);
        setBackgroundColor(Color.WHITE);
    }

    @Override
    protected void onDraw(Canvas canvas) {
        super.onDraw(canvas);

        paint.setAntiAlias(true);
        paint.setStrokeWidth(5f);

        // 1. Filled Red Circle
        paint.setColor(Color.RED);
        paint.setStyle(Paint.Style.FILL);
        canvas.drawCircle(200, 150, 80, paint);
        paint.setColor(Color.BLACK);
        paint.setTextSize(30f);
        canvas.drawText("Circle", 160, 260, paint);

        // 2. Blue Rectangle (outline)
        paint.setColor(Color.BLUE);
        paint.setStyle(Paint.Style.STROKE);
        canvas.drawRect(350, 70, 600, 230, paint);
        paint.setColor(Color.BLACK);
        canvas.drawText("Rectangle", 360, 260, paint);

        // 3. Green Filled Triangle
        paint.setColor(Color.GREEN);
        paint.setStyle(Paint.Style.FILL);
        Path triangle = new Path();
        triangle.moveTo(750, 70);
        triangle.lineTo(650, 230);
        triangle.lineTo(850, 230);
        triangle.close();
        canvas.drawPath(triangle, paint);
        paint.setColor(Color.BLACK);
        canvas.drawText("Triangle", 700, 260, paint);

        // 4. Orange Line
        paint.setColor(Color.parseColor("#FF6F00"));
        paint.setStyle(Paint.Style.STROKE);
        paint.setStrokeWidth(8f);
        canvas.drawLine(100, 340, 500, 340, paint);
        paint.setColor(Color.BLACK);
        paint.setTextSize(30f);
        canvas.drawText("Line", 280, 380, paint);

        // 5. Purple Oval
        paint.setColor(Color.parseColor("#7B1FA2"));
        paint.setStyle(Paint.Style.FILL);
        canvas.drawOval(550, 300, 900, 420, paint);
        paint.setColor(Color.BLACK);
        canvas.drawText("Oval", 700, 460, paint);

        // 6. Cyan Arc
        paint.setColor(Color.CYAN);
        paint.setStyle(Paint.Style.STROKE);
        paint.setStrokeWidth(6f);
        RectF arcRect = new RectF(100, 480, 350, 650);
        canvas.drawArc(arcRect, 0, 270, false, paint);
        paint.setColor(Color.BLACK);
        canvas.drawText("Arc", 190, 690, paint);

        // 7. Pink Rounded Rectangle
        paint.setColor(Color.parseColor("#F06292"));
        paint.setStyle(Paint.Style.FILL);
        RectF roundRect = new RectF(420, 480, 700, 640);
        canvas.drawRoundRect(roundRect, 30, 30, paint);
        paint.setColor(Color.BLACK);
        canvas.drawText("Rounded Rect", 420, 690, paint);

        // 8. Colored Text
        paint.setColor(Color.parseColor("#3F51B5"));
        paint.setTextSize(40f);
        paint.setStyle(Paint.Style.FILL);
        canvas.drawText("Hello Graphics!", 200, 780, paint);
    }
}
